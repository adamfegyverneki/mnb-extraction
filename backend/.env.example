# Copy to `.env` and fill in values. Used by Serverless and local scripts.
# For `--stage prod`, deploy scripts merge this into `.env.prod` with stage MongoDB DB name.

FRONTEND_ORIGIN=https://mnb-extraction.49x.ai

# Cluster URI (same for dev/staging/prod); database name differs per stage.
MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=49x-mnb-extraction-prod

HEALTH_TOKEN=
APP_VERSION=1.0.0

SERVERLESS_DEPLOYMENT_BUCKET=mnb-extraction.49x.ai

# From S3 secrets pull (./scripts/initial-setup/pull-s3-secrets.sh)
ZEUS_MONITOR_MONGODB_URI=
MONGODB_ATLAS_PUBLIC_API_KEY=
MONGODB_ATLAS_PRIVATE_API_KEY=
MONGODB_ATLAS_ORG_ID=

LOCAL_BACKEND_URL=http://localhost:4000
BACKEND_HTTP_PORT=4000
BACKEND_LAMBDA_PORT=3002
